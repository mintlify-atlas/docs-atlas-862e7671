  "keyFeatures": [
    "Two-table versioning system with immutable history",
    "Dynamic variable resolution with {{variable}} syntax",
    "Sub-100ms full-text search using PostgreSQL tsvector",
    "MCP server for AI agent integration (Claude, Cursor)",
    "Public sharing links for prompts",
    "Collections for organizing prompts",
    "API key management for programmatic access",
    "Kanagawa-themed UI optimized for 400px sidecar width"
  ],
